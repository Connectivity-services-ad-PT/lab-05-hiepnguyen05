      "item": [
        {
          "name": "6. POST /vision/detect - Missing Authorization Header",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"cameraId\":\"CAM-001\",\"imageRef\":\"s3://camera-frames/gate-01/test.jpg\",\"timestamp\":\"2026-05-26T08:00:00Z\",\"motionConfidence\":0.95}"
            },
            "url": {
