  "item": [
    {
      "name": "00_Health",
      "item": [
        {
          "name": "1. GET /health - Happy Path",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Service is ok', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.eql('ok');",
                  "    pm.expect(jsonData.service).to.eql('ai-vision-service');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01_Functional",
      "item": [
        {
          "name": "2. POST /vision/detect - Happy Path (Object Detection)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"cameraId\":\"CAM-001\",\"imageRef\":\"s3://camera-frames/gate-01/20260526-080000.jpg\",\"timestamp\":\"2026-05-26T08:00:00Z\",\"motionConfidence\":0.95}"
            },
            "url": {
              "raw": "{{baseUrl}}/vision/detect",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "vision",
                "detect"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Response has detectionId and objects list', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('detectionId');",
                  "    pm.expect(jsonData.detectedObjects).to.be.an('array');",
                  "    pm.environment.set('savedDetectionId', jsonData.detectionId);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "3. POST /vision/face-match - Happy Path (Face Match with Liveness)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"cameraId\":\"CAM-002\",\"imageRef\":\"s3://camera-frames/lobby/20260526-080100.jpg\",\"timestamp\":\"2026-05-26T08:01:00Z\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/vision/face-match",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "vision",
                "face-match"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Face match response is valid and includes liveness info', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('faceMatched');",
                  "    pm.expect(jsonData).to.have.property('isLive');",
                  "    pm.expect(jsonData.isLive).to.be.a('boolean');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "4. GET /vision/detections/{id} - Get Detection Detail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/vision/detections/{{savedDetectionId}}",
