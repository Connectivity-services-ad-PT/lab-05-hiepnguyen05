          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Unauthorized request returns 401 or 403', function () {",
                  "    pm.expect([401, 403]).to.include(pm.response.code);",
                  "});",
                  "pm.test('Response body follows ProblemDetails model', function () {",
                  "    var jsonData = pm.response.json();",
