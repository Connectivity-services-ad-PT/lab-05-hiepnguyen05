              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "vision",
                "detections"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "1000"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Large pagination limit boundary either succeeds capped or returns 400/422', function () {",
                  "    pm.expect([200, 400, 422]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
